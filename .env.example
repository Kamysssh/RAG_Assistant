# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Опционально: прокси / совместимый с OpenAI API endpoint
# OPENAI_BASE_URL=

# Таймауты HTTP (секунды), если ConnectTimeout / SSL handshake timed out
# OPENAI_CONNECT_TIMEOUT=120
# OPENAI_READ_TIMEOUT=180

# Модели
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Эмбеддинги: local (по умолчанию в коде) — без OpenAI Embeddings API; openai — только API.
# При 403 unsupported_country_region_territory на индексации оставьте local или задайте OPENAI_BASE_URL.
EMBEDDINGS_BACKEND=local

# LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Семантический кеш: порог косинусного сходства 0..1
# SEMANTIC_CACHE_THRESHOLD=0.88

# При значении 1 — полная переиндексация Chroma при старте RAGPipeline
RAG_FORCE_REINDEX=0

# --- Google Docs: база знаний (по умолчанию ссылки заданы в assistant_api/config.py) ---
# Переопределить: через запятую ID или полные ссылки. Документы: «Просмотр по ссылке».
# KNOWLEDGE_HR_GOOGLE_DOCS=
# KNOWLEDGE_POST_SALES_GOOGLE_DOCS=
# KNOWLEDGE_SALES_GOOGLE_DOCS=
#
# If Google Docs export fails with SSL errors (antivirus/VPN): try GOOGLE_DOCS_SSL_VERIFY=0
# (insecure, debugging only). Or disable HTTPS scanning in AV / turn off VPN.
# GOOGLE_DOCS_SSL_VERIFY=1
