# ========= OpenAI project (assistant_api) =========
# API key from OpenAI dashboard
OPENAI_API_KEY=your-openai-api-key

# ========= GigaChat project (assistant_giga) =========
# Basic authorization key (without "Basic " prefix)
GIGACHAT_AUTH_KEY=your-gigachat-auth-key
# Unique request ID (UUID format is recommended)
GIGACHAT_RQUID=00000000-0000-0000-0000-000000000000
# Embeddings mode for GigaChat project:
# - auto  : try GigaChat embeddings first, fallback to local on 402/403
# - local : always use local embeddings (no request to /embeddings endpoint)
GIGACHAT_EMBEDDINGS_PROVIDER=auto
# Local fallback embeddings model
GIGACHAT_FALLBACK_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Optional: set to 1 to rebuild vector index on startup
RAG_FORCE_REINDEX=0
